---
import BaseLayout from "../layouts/BaseLayout.astro";
import { services } from "../config/services";

const metadata = {
    title: "Uslugi",
    description: "Kompleksowe uslugi SEO, Web Development i Strategii dla firm B2B.",
};
---

<BaseLayout {metadata}>
    <section class="pt-40 pb-24 px-6 md:px-12 lg:px-24">
        <div class="max-w-7xl mx-auto">
            <div class="mb-20 reveal-on-scroll">
                <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Uslugi</span>
                <h1 class="font-serif text-5xl md:text-7xl leading-tight text-balance">
                    Kompleksowe rozwiazania <br/>
                    <span class="text-muted-foreground italic">dla sektora B2B</span>
                </h1>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16">
                {services.map((service) => (
                    <article class="group border-t border-border pt-6 reveal-on-scroll">
                        <span class="block text-4xl font-serif text-border mb-4 group-hover:text-foreground transition-colors duration-500">{service.num}</span>
                        <h2 class="text-2xl font-bold mb-3">{service.title}</h2>
                        <p class="text-muted-foreground text-sm leading-relaxed mb-4">{service.description}</p>
                        <ul class="text-xs text-muted-foreground/70 flex flex-col gap-1 uppercase tracking-wide">
                            {service.tags.map((tag) => (
                                <li>&mdash; {tag}</li>
                            ))}
                        </ul>
                    </article>
                ))}
            </div>
            <div class="mt-20 text-center reveal-on-scroll">
                <a class="inline-block bg-foreground text-background px-8 py-4 rounded-full font-medium hover:scale-105 transition-transform" href="/#contact">
                    Porozmawiajmy o Twoim projekcie
                </a>
            </div>
        </div>
    </section>
</BaseLayout>
