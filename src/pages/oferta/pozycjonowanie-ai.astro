---
import BaseLayout from "../../layouts/BaseLayout.astro";

const metadata = {
    title: "Pozycjonowanie w AI",
    description: "Optymalizacja widocznosci Twojej marki w wynikach AI - ChatGPT, Gemini, Perplexity, Copilot. Nowa era wyszukiwania wymaga nowego podejscia.",
};

const whyNow = [
    {
        title: "AI przejmuje wyszukiwanie",
        description: "Coraz wiecej uzytkownikow szuka odpowiedzi w ChatGPT, Gemini czy Perplexity zamiast w Google. Twoja marka musi byc widoczna rowniez w tych kanalach.",
    },
    {
        title: "Zero-click era",
        description: "AI generuje odpowiedzi bez klikania w linki. Jesli Twoja marka nie jest cytowana przez AI, tracisz widocznosc w nowej generacji wyszukiwania.",
    },
    {
        title: "Przewaga pierwszego gracza",
        description: "Wiekszosc firm jeszcze nie optymalizuje pod AI. To okno mozliwosci - kto zacznie teraz, zbuduje pozycje trudna do przebicia przez konkurencje.",
    },
];

const scope = [
    {
        num: "01",
        title: "Audyt widocznosci w AI",
        description: "Sprawdzamy, jak Twoja marka i produkty sa prezentowane w odpowiedziach ChatGPT, Gemini, Perplexity, Copilot i innych narzedzi AI.",
    },
    {
        num: "02",
        title: "Strategia tresci pod AI",
        description: "Tworzymy tresci zoptymalizowane pod sposob, w jaki modele jezykowe zbieraja i prezentuja informacje. Strukturalne, jednoznaczne, autorytatywne.",
    },
    {
        num: "03",
        title: "Optymalizacja zrodel",
        description: "Budujemy autorytet Twojej marki w zrodlach, z ktorych AI czerpie wiedze - Wikipedia, branżowe bazy danych, tresci eksperckie, PR cyfrowy.",
    },
    {
        num: "04",
        title: "Dane strukturalne dla AI",
        description: "Implementacja rozszerzonych znacznikow Schema.org, OpenGraph i meta danych, ktore AI wykorzystuje do budowania odpowiedzi.",
    },
    {
        num: "05",
        title: "Monitoring i raportowanie",
        description: "Regularne sprawdzanie, jak modele AI prezentuja Twoja marke. Sledzenie zmian i optymalizacja strategii w oparciu o realne wyniki.",
    },
    {
        num: "06",
        title: "Brand authority building",
        description: "Budowanie autorytetu marki w ekosystemie AI poprzez PR cyfrowy, publikacje eksperckie i obecnosc w kluczowych bazach wiedzy.",
    },
];

const platforms = [
    { name: "ChatGPT / OpenAI", description: "Najczesciej uzywane narzedzie AI. Optymalizujemy tresci, by Twoja marka pojawiala sie w odpowiedziach GPT." },
    { name: "Google Gemini", description: "AI Overviews w wynikach Google. Kluczowe dla utrzymania widocznosci w ekosystemie Google." },
    { name: "Perplexity AI", description: "Wyszukiwarka AI ze zrodlami. Budujemy obecnosc Twojej marki w cytowanych odpowiedziach." },
    { name: "Microsoft Copilot", description: "Integracja z Bing i Microsoft 365. Optymalizacja pod Copilot w kontekscie B2B." },
];
---

<BaseLayout {metadata}>
    <!-- Hero -->
    <section class="relative pt-40 pb-24 px-6 md:px-12 lg:px-24 border-b border-border">
        <div class="max-w-5xl mx-auto">
            <div class="reveal-on-scroll">
                <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Oferta</span>
                <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl leading-[1.1] mb-8 text-balance">
                    Pozycjonowanie <span class="italic text-muted-foreground">w AI</span>
                </h1>
                <div class="flex items-center gap-4">
                    <div class="w-16 h-px bg-foreground shrink-0"></div>
                    <p class="text-lg max-w-xl text-muted-foreground leading-relaxed">
                        Nowa era wyszukiwania juz trwa. Zadbaj o widocznosc swojej marki nie tylko w Google, ale takze w odpowiedziach ChatGPT, Gemini i Perplexity.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Why Now -->
    <section class="py-32 px-6 md:px-12 lg:px-24 bg-muted">
        <div class="max-w-5xl mx-auto">
            <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block reveal-on-scroll">Kontekst</span>
            <h2 class="font-serif text-4xl md:text-6xl lg:text-7xl leading-tight reveal-on-scroll text-pretty mb-16">
                Dlaczego <span class="text-muted-foreground italic">teraz?</span>
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-lg leading-relaxed text-muted-foreground">
                {whyNow.map((item) => (
                    <div class="reveal-on-scroll">
                        <p class="mb-4 font-medium text-foreground text-xl">{item.title}</p>
                        <p>{item.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Scope -->
    <section class="py-32 px-6 md:px-12 lg:px-24">
        <div class="max-w-7xl mx-auto">
            <div class="mb-20 reveal-on-scroll">
                <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Zakres</span>
                <h2 class="font-serif text-4xl md:text-6xl leading-tight text-balance">
                    Co obejmuje <span class="italic text-muted-foreground">pozycjonowanie w AI?</span>
                </h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16">
                {scope.map((item) => (
                    <article class="group border-t border-border pt-6 reveal-on-scroll">
                        <span class="block text-4xl font-serif text-border mb-4 group-hover:text-foreground transition-colors duration-500">{item.num}</span>
                        <h3 class="text-xl font-bold mb-3">{item.title}</h3>
                        <p class="text-muted-foreground text-sm leading-relaxed">{item.description}</p>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <!-- Platforms -->
    <section class="py-32 px-6 md:px-12 lg:px-24 bg-card">
        <div class="max-w-7xl mx-auto">
            <div class="mb-16 reveal-on-scroll">
                <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Platformy AI</span>
                <h2 class="font-serif text-4xl md:text-6xl leading-tight text-balance">
                    Gdzie budujemy <span class="italic text-muted-foreground">Twoja widocznosc?</span>
                </h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {platforms.map((platform) => (
                    <div class="border-t border-border pt-6 reveal-on-scroll">
                        <h3 class="text-xl font-bold mb-3">{platform.name}</h3>
                        <p class="text-muted-foreground leading-relaxed">{platform.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-32 px-6 md:px-12 lg:px-24">
        <div class="max-w-5xl mx-auto text-center reveal-on-scroll">
            <h2 class="font-serif text-4xl md:text-6xl lg:text-7xl mb-8 text-balance">
                Badz tam, gdzie szuka Twoj klient.
            </h2>
            <p class="text-lg text-muted-foreground max-w-2xl mx-auto mb-12 leading-relaxed">
                Sprawdzimy, jak Twoja marka wyglada w oczach AI i zaproponujemy strategie na zbudowanie widocznosci w nowej erze wyszukiwania.
            </p>
            <a class="inline-block bg-foreground text-background px-8 py-4 rounded-full font-medium hover:scale-105 transition-transform" href="/#contact">
                Sprawdz widocznosc w AI
            </a>
        </div>
    </section>
</BaseLayout>
