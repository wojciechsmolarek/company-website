---
import BaseLayout from "../../layouts/BaseLayout.astro";

const metadata = {
    title: "SEO Techniczne",
    description: "Kompleksowe audyty i optymalizacja techniczna SEO. Poprawiamy wydajnosc, indeksowalnosc i strukture Twojej strony, by Google ja pokochal.",
};

const processSteps = [
    {
        num: "01",
        title: "Audyt techniczny",
        description: "Szczegolowa analiza Twojej strony pod katem wydajnosci, indeksowalnosci, struktury URL, linkowania wewnetrznego, Schema.org, Core Web Vitals i wielu innych czynnikow.",
    },
    {
        num: "02",
        title: "Priorytetyzacja zadan",
        description: "Kazdy problem oceniamy pod katem wplywu na widocznosc. Tworzymy liste zadan podzielona na szybkie wygrane i strategiczne zmiany dlugoterminowe.",
    },
    {
        num: "03",
        title: "Wdrozenie i nadzor",
        description: "Wspieramy Twoj zespol deweloperski lub sami wdrazamy zmiany. Monitorujemy efekty kazdej optymalizacji i raportujemy postepy.",
    },
];

const features = [
    {
        title: "Core Web Vitals",
        description: "Optymalizacja LCP, FID i CLS - kluczowych wskaznikow doswiadczenia uzytkownika, ktore bezposrednio wplywaja na ranking.",
    },
    {
        title: "Indeksowalnosc",
        description: "Zapewniamy, ze roboty Google efektywnie crawluja i indeksuja najwazniejsze podstrony Twojego serwisu.",
    },
    {
        title: "Architektura informacji",
        description: "Struktura URL, linkowanie wewnetrzne, breadcrumbs - budujemy logiczna hierarchie, ktora wspiera SEO i UX.",
    },
    {
        title: "Dane strukturalne",
        description: "Implementacja Schema.org dla lepszej prezentacji w wynikach wyszukiwania - rich snippets, FAQ, breadcrumbs i inne.",
    },
    {
        title: "Optymalizacja crawl budget",
        description: "Zarzadzanie plikami robots.txt, canonical, hreflang i paginacja - by Google skupil sie na tym, co najwazniejsze.",
    },
    {
        title: "Bezpieczenstwo i HTTPS",
        description: "Pelna migracja na HTTPS, konfiguracja naglowkow bezpieczenstwa, eliminacja mixed content i podatnosci.",
    },
];
---

<BaseLayout {metadata}>
    <!-- Hero -->
    <section class="relative pt-40 pb-24 px-6 md:px-12 lg:px-24 border-b border-border">
        <div class="max-w-5xl mx-auto">
            <div class="reveal-on-scroll">
                <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Oferta</span>
                <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl leading-[1.1] mb-8 text-balance">
                    SEO <span class="italic text-muted-foreground">Techniczne</span>
                </h1>
                <div class="flex items-center gap-4">
                    <div class="w-16 h-px bg-foreground shrink-0"></div>
                    <p class="text-lg max-w-xl text-muted-foreground leading-relaxed">
                        Solidne fundamenty techniczne to podstawa kazdej strategii SEO. Audytujemy, priorytetyzujemy i wdrazamy zmiany, ktore realnie wplywaja na widocznosc.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Process Steps -->
    <section class="py-32 px-6 md:px-12 lg:px-24 bg-muted">
        <div class="max-w-7xl mx-auto">
            <h2 class="font-serif text-4xl md:text-6xl mb-16 reveal-on-scroll text-balance">Jak pracujemy?</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                {processSteps.map((step) => (
                    <div class="reveal-on-scroll">
                        <span class="block text-6xl font-serif text-border mb-6">{step.num}</span>
                        <h3 class="text-xl font-bold mb-4">{step.title}</h3>
                        <p class="text-muted-foreground leading-relaxed">{step.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Features Grid -->
    <section class="py-32 px-6 md:px-12 lg:px-24">
        <div class="max-w-7xl mx-auto">
            <div class="mb-20 reveal-on-scroll">
                <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Zakres</span>
                <h2 class="font-serif text-4xl md:text-6xl leading-tight text-balance">
                    Co obejmuje <span class="italic text-muted-foreground">audyt techniczny?</span>
                </h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16">
                {features.map((feature) => (
                    <article class="group border-t border-border pt-6 reveal-on-scroll">
                        <h3 class="text-xl font-bold mb-3">{feature.title}</h3>
                        <p class="text-muted-foreground text-sm leading-relaxed">{feature.description}</p>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-32 bg-card px-6 md:px-12 lg:px-24">
        <div class="max-w-5xl mx-auto text-center reveal-on-scroll">
            <h2 class="font-serif text-4xl md:text-6xl lg:text-7xl mb-8 text-balance">
                Twoja strona moze wiecej.
            </h2>
            <p class="text-lg text-muted-foreground max-w-2xl mx-auto mb-12 leading-relaxed">
                Bezplatna rozmowa o technicznych mozliwosciach Twojego serwisu. Pokaz nam strone, a powiemy Ci, co mozna poprawic.
            </p>
            <a class="inline-block bg-foreground text-background px-8 py-4 rounded-full font-medium hover:scale-105 transition-transform" href="/#contact">
                Zamow bezplatna konsultacje
            </a>
        </div>
    </section>
</BaseLayout>
