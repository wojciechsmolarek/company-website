---
import BaseLayout from "../layouts/BaseLayout.astro";
import Form from "../components/ui/Form.astro";

const metadata = {
    title: "Kontakt",
    description: "Skontaktuj sie z nami, aby omowic Twoj projekt B2B.",
};
---

<BaseLayout {metadata}>
    <section class="pt-40 pb-32 px-6 md:px-12 lg:px-24">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
                <div class="reveal-on-scroll">
                    <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">Kontakt</span>
                    <h1 class="font-serif text-5xl md:text-7xl leading-tight mb-8 text-balance">
                        <span class="inline-block" aria-hidden="true">&rarr;</span> Porozmawiajmy
                    </h1>
                    <p class="text-muted-foreground text-lg max-w-md leading-relaxed mb-8">
                        Masz projekt? Potrzebujesz konsultacji? A moze po prostu chcesz zapytac o mozliwosci wspolpracy? Napisz do nas.
                    </p>
                    <a
                        class="inline-block text-2xl border-b border-muted-foreground pb-2 hover:border-foreground transition-colors"
                        href="mailto:hello@b2bcollective.pl"
                    >
                        hello@b2bcollective.pl
                    </a>

                    <div class="mt-16 grid grid-cols-2 gap-12">
                        <div>
                            <h3 class="uppercase tracking-widest text-xs font-medium mb-4">Telefon</h3>
                            <p class="text-muted-foreground">+48 123 456 789</p>
                        </div>
                        <div>
                            <h3 class="uppercase tracking-widest text-xs font-medium mb-4">Lokalizacja</h3>
                            <p class="text-muted-foreground">Warszawa, Polska</p>
                        </div>
                    </div>
                </div>

                <div class="bg-card border border-border p-8 md:p-12 rounded-lg reveal-on-scroll">
                    <Form />
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
