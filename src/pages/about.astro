---
import BaseLayout from "../layouts/BaseLayout.astro";
import { experts } from "../config/experts";

const metadata = {
    title: "O nas",
    description: "Poznaj zespol B2B Collective - kolektyw ekspertow SEO, Web Development i Strategii.",
};
---

<BaseLayout {metadata}>
    <!-- Hero -->
    <section class="pt-40 pb-24 px-6 md:px-12 lg:px-24">
        <div class="max-w-5xl mx-auto reveal-on-scroll">
            <span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block">O nas</span>
            <h1 class="font-serif text-5xl md:text-7xl leading-tight mb-8 text-balance">
                Kolektyw ekspertow, <br/>
                <span class="italic text-muted-foreground">nie agencja.</span>
            </h1>
            <div class="flex items-center gap-4">
                <div class="w-16 h-px bg-foreground shrink-0"></div>
                <p class="text-lg max-w-xl text-muted-foreground leading-relaxed">
                    Trojka specjalistow z wieloletnim doswiadczeniem w B2B. Bez rozbudowanych struktur - bezposredni kontakt z osobami, ktore wykonuja prace.
                </p>
            </div>
        </div>
    </section>

    <!-- Team -->
    <section class="pb-32 px-6 md:px-12 lg:px-24">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {experts.map((expert, i) => (
                    <div class="group reveal-on-scroll">
                        <div class="relative overflow-hidden mb-6 bg-muted aspect-[3/4]">
                            <img
                                alt={expert.name}
                                class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110 grayscale group-hover:grayscale-0"
                                src={expert.image}
                                loading="lazy"
                            />
                            <div class="absolute top-4 left-4 text-white font-mono text-sm opacity-60">{String(i + 1).padStart(2, '0')}</div>
                        </div>
                        <h3 class="text-2xl font-serif mb-1">{expert.name}</h3>
                        <p class="text-sm font-bold uppercase tracking-wide text-muted-foreground mb-2">{expert.role}</p>
                        <p class="text-sm text-muted-foreground leading-relaxed border-t border-border pt-3">{expert.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Values -->
    <section class="py-32 bg-muted px-6 md:px-12 lg:px-24">
        <div class="max-w-5xl mx-auto">
            <h2 class="font-serif text-4xl md:text-6xl lg:text-7xl leading-tight reveal-on-scroll text-pretty">
                Bez posrednikow. <br/>
                Bez project managerow. <br/>
                <span class="text-muted-foreground">Bezposredni kontakt z zalozycielami.</span>
            </h2>
            <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-12 text-lg leading-relaxed text-muted-foreground">
                <div class="reveal-on-scroll">
                    <p class="mb-4 font-medium text-foreground text-xl">Ekspertyza</p>
                    <p>Kazdy z nas jest specjalista w swojej dziedzinie z wieloletnim doswiadczeniem w sektorze B2B.</p>
                </div>
                <div class="reveal-on-scroll">
                    <p class="mb-4 font-medium text-foreground text-xl">Transparentnosc</p>
                    <p>Widzisz caly proces, znasz kazdego czlonka zespolu. Nie ukrywamy sie za strukturami korporacyjnymi.</p>
                </div>
                <div class="reveal-on-scroll">
                    <p class="mb-4 font-medium text-foreground text-xl">Efektywnosc</p>
                    <p>Bez zbednych warstw decyzyjnych. Szybsze wdrozenia, lepsza komunikacja, realne rezultaty.</p>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
