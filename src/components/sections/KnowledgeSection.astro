---
interface Article {
	image: { src: string; alt: string };
	category: string;
	title: string;
	excerpt: string;
}

interface Props {
	articles: Article[];
}

const { articles } = Astro.props;
---

<section class="py-32 px-6 md:px-12 lg:px-24 bg-muted" id="knowledge">
	<div class="max-w-7xl mx-auto">
		<div class="flex justify-between items-center mb-16 reveal-on-scroll">
			<h2 class="font-serif text-4xl md:text-5xl">Baza Wiedzy</h2>
			<a class="hidden md:block text-sm uppercase tracking-widest hover:underline" href="#">
				{'Zobacz wszystkie \u2192'}
			</a>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			{articles.map((article) => (
				<article class="group cursor-pointer reveal-on-scroll">
					<div class="overflow-hidden mb-6 bg-border aspect-video relative">
						<img
							alt={article.image.alt}
							class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105"
							src={article.image.src}
							loading="lazy"
						/>
						<div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors"></div>
					</div>
					<span class="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-2 block">{article.category}</span>
					<h3 class="text-2xl font-serif leading-tight mb-3 group-hover:underline decoration-1 underline-offset-4">{article.title}</h3>
					<p class="text-sm text-muted-foreground line-clamp-3">{article.excerpt}</p>
				</article>
			))}
		</div>
	</div>
</section>
