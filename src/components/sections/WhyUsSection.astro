---
interface Props {
	tagline: string;
	headline: string;
	description: string;
}

const { tagline, headline, description } = Astro.props;
---

<section class="py-32 bg-muted px-6 md:px-12 lg:px-24 relative overflow-hidden">
	<div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-border/40 to-transparent pointer-events-none"></div>
	<div class="max-w-5xl mx-auto relative z-10">
		<span class="text-sm uppercase tracking-widest text-muted-foreground mb-4 block reveal-on-scroll">{tagline}</span>
		<h2 class="font-serif text-4xl md:text-6xl lg:text-7xl leading-tight reveal-on-scroll text-pretty" set:html={headline} />
		<div class="mt-12 flex items-center gap-4 reveal-on-scroll">
			<div class="w-16 h-px bg-foreground shrink-0"></div>
			<p class="text-lg max-w-xl text-muted-foreground leading-relaxed">{description}</p>
		</div>
	</div>
</section>
