---
interface ServiceItem {
	num: string;
	title: string;
	description: string;
	tags: string[];
}

interface Props {
	services: ServiceItem[];
}

const { services } = Astro.props;
---

<section class="py-24 px-6 md:px-12 lg:px-24 border-b border-border" id="services">
	<div class="max-w-7xl mx-auto">
		<div class="mb-20 flex justify-between items-end reveal-on-scroll">
			<h2 class="font-serif text-5xl md:text-6xl">Services</h2>
			<a class="group flex items-center gap-2 text-sm uppercase tracking-widest hover:text-muted-foreground transition" href="/services">
				Pelna oferta
				<span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
			</a>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16">
			{services.map((service) => (
				<article class="group border-t border-border pt-6 reveal-on-scroll">
					<span class="block text-4xl font-serif text-border mb-4 group-hover:text-foreground transition-colors duration-500">{service.num}</span>
					<h3 class="text-2xl font-bold mb-3">{service.title}</h3>
					<p class="text-muted-foreground text-sm leading-relaxed mb-4">{service.description}</p>
					<ul class="text-xs text-muted-foreground/70 flex flex-col gap-1 uppercase tracking-wide">
						{service.tags.map((tag) => (
							<li>&mdash; {tag}</li>
						))}
					</ul>
				</article>
			))}
		</div>
		<div class="mt-20 text-center reveal-on-scroll">
			<a class="inline-block border-b border-foreground pb-1 text-lg hover:opacity-70 transition" href="#contact">
				Dowiedz sie wiecej o procesie
			</a>
		</div>
	</div>
</section>
