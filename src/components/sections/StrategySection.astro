---
interface StrategyColumn {
	title: string;
	description: string;
}

interface Props {
	headline: string;
	columns: StrategyColumn[];
}

const { headline, columns } = Astro.props;
---

<section class="py-32 px-6 md:px-12 lg:px-24 bg-card">
	<div class="max-w-7xl mx-auto">
		<h2 class="font-serif text-5xl md:text-7xl mb-16 text-center reveal-on-scroll text-balance">{headline}</h2>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-lg leading-relaxed text-muted-foreground">
			{columns.map((col) => (
				<div class="reveal-on-scroll">
					<p class="mb-6 font-medium text-foreground text-xl">{col.title}</p>
					<p set:html={col.description} />
				</div>
			))}
		</div>
		<div class="mt-16 w-full h-px bg-border reveal-on-scroll"></div>
	</div>
</section>
