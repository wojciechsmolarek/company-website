---
import { siteConfig } from "../../config/site";
import Form from "../ui/Form.astro";
---

<footer class="bg-foreground text-background pt-32 pb-12 px-6 md:px-12 lg:px-24" id="contact">
    <div class="max-w-7xl mx-auto">
        <!-- Contact Section -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mb-24">
            <div class="reveal-on-scroll">
                <h2 class="font-serif text-5xl md:text-6xl lg:text-7xl xl:text-8xl leading-none mb-8">
                    <span class="inline-block" aria-hidden="true">&rarr;</span> Porozmawiajmy
                </h2>
                <p class="text-background/60 text-lg max-w-md leading-relaxed">
                    Masz projekt? Potrzebujesz konsultacji? A moze po prostu chcesz zapytac o mozliwosci wspolpracy? Napisz do nas.
                </p>
                <a
                    class="mt-8 inline-block text-2xl border-b border-background/40 pb-2 hover:border-background transition-colors"
                    href="mailto:hello@b2bcollective.pl"
                >
                    hello@b2bcollective.pl
                </a>
            </div>
            <div class="bg-background/5 p-8 md:p-12 rounded-lg border border-background/10 reveal-on-scroll">
                <Form />
            </div>
        </div>

        <!-- Footer Bottom -->
        <div class="border-t border-background/10 pt-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-8 text-sm text-background/50">
            <div class="grid grid-cols-2 gap-12">
                <div>
                    <h4 class="text-background mb-4 uppercase tracking-widest text-xs font-medium">Kontakt</h4>
                    <p>+48 123 456 789</p>
                    <p>Warszawa, Polska</p>
                </div>
                <div>
                    <h4 class="text-background mb-4 uppercase tracking-widest text-xs font-medium">Social</h4>
                    <ul class="flex flex-col gap-2">
                        <li><a class="hover:text-background transition" href={siteConfig.socialLinks.linkedin}>LinkedIn</a></li>
                        <li><a class="hover:text-background transition" href={siteConfig.socialLinks.twitter}>Twitter</a></li>
                    </ul>
                </div>
            </div>
            <div class="text-xs">
                &copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.
                <a class="underline ml-2 hover:text-background transition" href="#">Privacy Policy</a>
            </div>
        </div>
    </div>
</footer>
