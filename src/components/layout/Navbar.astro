---
import { siteConfig } from "../../config/site";
---

<nav
    class="fixed top-0 w-full z-50 px-6 py-5 flex justify-between items-center mix-blend-difference text-white pointer-events-none"
>
    <div class="pointer-events-auto">
        <a href="/" aria-label="B2B Collective Home">
            <svg class="text-white" fill="currentColor" height="32" viewBox="0 0 24 24" width="32" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
            </svg>
        </a>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden md:flex gap-8 text-sm uppercase tracking-widest font-medium pointer-events-auto">
        {
            siteConfig.navLinks.map((link) => (
                <a
                    href={link.href}
                    class="hover:underline underline-offset-4 transition-all"
                >
                    {link.text}
                </a>
            ))
        }
    </div>

    <div class="pointer-events-auto">
        <button
            id="mobile-menu-button"
            class="bg-white text-black px-6 py-2 rounded-full font-medium hover:bg-gray-200 transition text-sm"
            type="button"
            aria-controls="mobile-menu"
            aria-expanded="false"
        >
            Menu
        </button>
    </div>
</nav>

<!-- Mobile Full-Screen Menu -->
<div id="mobile-menu" class="fixed inset-0 z-[60] bg-foreground text-background hidden flex-col items-center justify-center">
    <button
        id="mobile-menu-close"
        class="absolute top-5 right-6 text-background hover:opacity-70 transition"
        aria-label="Close menu"
    >
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
    </button>
    <div class="flex flex-col items-center gap-8">
        {
            siteConfig.navLinks.map((link) => (
                <a
                    href={link.href}
                    class="text-3xl font-serif hover:opacity-70 transition mobile-menu-link"
                >
                    {link.text}
                </a>
            ))
        }
    </div>
</div>

<script>
    const button = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");
    const closeButton = document.getElementById("mobile-menu-close");

    function openMenu() {
        menu?.classList.remove("hidden");
        menu?.classList.add("flex");
        button?.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
    }

    function closeMenu() {
        menu?.classList.add("hidden");
        menu?.classList.remove("flex");
        button?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
    }

    button?.addEventListener("click", openMenu);
    closeButton?.addEventListener("click", closeMenu);

    document.querySelectorAll(".mobile-menu-link").forEach((link) => {
        link.addEventListener("click", closeMenu);
    });
</script>
